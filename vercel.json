{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.mankariders.xyz/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://api.mankariders.xyz/storage/:path*"
    },
    {
      "source": "/broadcasting/:path*",
      "destination": "https://api.mankariders.xyz/broadcasting/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
