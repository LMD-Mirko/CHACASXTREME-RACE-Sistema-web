{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://enzyme-blog-reliance-franklin.trycloudflare.com/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "https://enzyme-blog-reliance-franklin.trycloudflare.com/storage/:path*"
    },
    {
      "source": "/broadcasting/:path*",
      "destination": "https://enzyme-blog-reliance-franklin.trycloudflare.com/broadcasting/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
